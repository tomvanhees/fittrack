# Supabase — kopieer dit bestand naar `.env` en vul je projectwaarden in.
# Te vinden in Supabase: Project Settings → API.
# Beide keys zijn publiek (de anon key wordt afgeschermd door Row Level Security),
# vandaar het EXPO_PUBLIC_-prefix zodat ze in de app-bundle beschikbaar zijn.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
